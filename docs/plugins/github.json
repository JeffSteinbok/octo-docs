{
  "plugin": "github",
  "name": "GitHub",
  "summary": "Manage GitHub issues. Create, read, update, close, comment on, and list issues.",
  "configuration": "Set credentials in `plugins.entries[\"github\"].config`:\n\n```json\n{\n  \"plugins\": {\n    \"entries\": {\n      \"github\": {\n        \"enabled\": true,\n        \"config\": {\n          \"token\": \"ghp_your_personal_access_token\"\n        }\n      }\n    }\n  }\n}\n```",
  "config_schema": {
    "type": "object",
    "properties": {
      "token": {
        "description": "GitHub personal access token or fine-grained token",
        "type": "string"
      }
    }
  },
  "env_vars": [],
  "tools": [
    {
      "name": "github_list_issues",
      "description": "List GitHub issues with optional filters. Filter by state (open/closed/all), labels, assignee, and milestone. Returns a list of issues and the total count.",
      "parameters": {
        "owner": {
          "type": "string",
          "required": true,
          "description": "Repository owner (user or organisation name)"
        },
        "repo": {
          "type": "string",
          "required": true,
          "description": "Repository name"
        },
        "state": {
          "type": "string",
          "required": false,
          "description": "Filter by state (default: open)"
        },
        "labels": {
          "type": "string",
          "required": false,
          "description": "Comma-separated list of labels to filter by"
        },
        "assignee": {
          "type": "string",
          "required": false,
          "description": "Filter by assignee username"
        },
        "milestone": {
          "type": "string",
          "required": false,
          "description": "Filter by milestone number or '*' for any milestone"
        },
        "per_page": {
          "type": "integer",
          "required": false,
          "description": "Results per page (default: 30, max: 100)"
        },
        "page": {
          "type": "integer",
          "required": false,
          "description": "Page number for pagination (default: 1)"
        }
      }
    },
    {
      "name": "github_get_issue",
      "description": "Get a single GitHub issue by its number. Returns issue details including title, body, state, labels, and assignees.",
      "parameters": {
        "owner": {
          "type": "string",
          "required": true,
          "description": "Repository owner (user or organisation name)"
        },
        "repo": {
          "type": "string",
          "required": true,
          "description": "Repository name"
        },
        "issue_number": {
          "type": "integer",
          "required": true,
          "description": "Issue number"
        }
      }
    },
    {
      "name": "github_create_issue",
      "description": "Create a new issue in a GitHub repository. Acts as the authenticated OpenClaw user (GITHUB_TOKEN). Returns the issue number, URL, and state.",
      "parameters": {
        "owner": {
          "type": "string",
          "required": true,
          "description": "Repository owner (user or organisation name)"
        },
        "repo": {
          "type": "string",
          "required": true,
          "description": "Repository name"
        },
        "title": {
          "type": "string",
          "required": true,
          "description": "Issue title"
        },
        "body": {
          "type": "string",
          "required": false,
          "description": "Issue body (Markdown supported). Defaults to empty string."
        },
        "labels": {
          "type": "array",
          "required": false,
          "description": "Labels to apply to the issue (must already exist in the repo)"
        },
        "assignees": {
          "type": "array",
          "required": false,
          "description": "GitHub usernames to assign the issue to"
        },
        "milestone": {
          "type": "integer",
          "required": false,
          "description": "Milestone number to associate with the issue"
        }
      }
    },
    {
      "name": "github_edit_issue",
      "description": "Edit an existing GitHub issue. Update title, body, state, labels, assignees, or milestone. At least one field to update must be provided.",
      "parameters": {
        "owner": {
          "type": "string",
          "required": true,
          "description": "Repository owner (user or organisation name)"
        },
        "repo": {
          "type": "string",
          "required": true,
          "description": "Repository name"
        },
        "issue_number": {
          "type": "integer",
          "required": true,
          "description": "Issue number"
        },
        "title": {
          "type": "string",
          "required": false,
          "description": "New issue title"
        },
        "body": {
          "type": "string",
          "required": false,
          "description": "New issue body (Markdown supported)"
        },
        "state": {
          "type": "string",
          "required": false,
          "description": "Issue state (open or closed)"
        },
        "labels": {
          "type": "array",
          "required": false,
          "description": "Labels to apply (replaces existing labels)"
        },
        "assignees": {
          "type": "array",
          "required": false,
          "description": "Assignees (replaces existing assignees)"
        },
        "milestone": {
          "type": "integer",
          "required": false,
          "description": "Milestone number"
        }
      }
    },
    {
      "name": "github_close_issue",
      "description": "Close or reopen a GitHub issue. By default closes the issue, set reopen=true to reopen it.",
      "parameters": {
        "owner": {
          "type": "string",
          "required": true,
          "description": "Repository owner (user or organisation name)"
        },
        "repo": {
          "type": "string",
          "required": true,
          "description": "Repository name"
        },
        "issue_number": {
          "type": "integer",
          "required": true,
          "description": "Issue number"
        },
        "reopen": {
          "type": "boolean",
          "required": false,
          "description": "Set to true to reopen the issue instead of closing it"
        }
      }
    },
    {
      "name": "github_comment_issue",
      "description": "Add a comment to a GitHub issue. Returns the comment ID, body, user, and URL.",
      "parameters": {
        "owner": {
          "type": "string",
          "required": true,
          "description": "Repository owner (user or organisation name)"
        },
        "repo": {
          "type": "string",
          "required": true,
          "description": "Repository name"
        },
        "issue_number": {
          "type": "integer",
          "required": true,
          "description": "Issue number"
        },
        "body": {
          "type": "string",
          "required": true,
          "description": "Comment body (Markdown supported)"
        }
      }
    }
  ],
  "public_types": [],
  "examples": [],
  "limitations": []
}